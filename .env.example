# overcast — sample environment file.
#
#   cp .env.example .env   # then fill in the keys/paths you have
#
# `.env` is gitignored (never commit real secrets). It is sourced by the LIVE
# real-data e2e suite (test/e2e/live/run.sh) and is a convenient place to keep
# provider creds for local CLI use. EVERYTHING here is OPTIONAL: each e2e case
# gates on what it needs and SKIPS (counted as pass) when a key/tool/clip is
# absent, so the suite runs green with any subset.

# ── Sense / brain providers ────────────────────────────────────────────────
# Default watch/listen backend (Cloudglue via the tinycloud CLI), also a pickable
# brain LLM. https://cloudglue.dev
CLOUDGLUE_API_KEY=
# Hugging Face — turnkey `see` captioner + `enhance`, and model downloads for the
# local object detector. https://huggingface.co/settings/tokens
HF_TOKEN=
# fal.ai — `see` (florence-2 caption/OCR) + `enhance` (esrgan). https://fal.ai/dashboard/keys
FAL_KEY=
# ElevenLabs — `listen` (Scribe STT) + `enhance` (voice isolation). https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── OSINT sources (scan/capture/monitor) ───────────────────────────────────
# Web search: Tavily preferred, Brave as fallback (set either).
TAVILY_API_KEY=
BRAVE_API_KEY=
# TikTok enumerate (Apify actor); fetch uses yt-dlp. https://apify.com
APIFY_TOKEN=

# ── Test media (LIVE e2e) — one full path per file ─────────────────────────
# Point each at a real local file (absolute path). No file names are baked into
# the repo. A case SKIPS when its file is unset or missing, so fill in only what
# you have.
# Videos:
OC_VIDEO_VISUAL=/path/to/screen-recording.mp4     # rich on-screen visual (~30s) — watch / see
OC_VIDEO_OBJECTS=/path/to/people-and-objects.mp4  # people + detectable objects — see --detect
OC_VIDEO_SMALL=/path/to/small-clip.mp4            # short / small — enhance / view
OC_VIDEO_SPEECH=/path/to/clip-with-speech.mp4     # clear spoken audio — listen (audio fallback)
# Standalone image + audio (used directly by see / listen; if unset, those fall
# back to a frame / audio extracted from the videos above):
OC_IMAGE=/path/to/photo.jpg                       # image — see (caption / OCR / detect)
OC_AUDIO=/path/to/recording.m4a                   # audio — listen

# ── Local object detector (see --detect) ──────────────────────────────────
# Python interpreter that has torch + transformers + scipy + pillow installed
# (OWLv2 / Grounding DINO). If unset, the case probes python3/python and skips
# when the deps aren't present. e.g. /path/to/venv/bin/python
DETECT_PY=
# Optional detector tuning (defaults shown):
# DETECT_MODEL=google/owlv2-base-patch16-ensemble
# DETECT_THRESHOLD=0.1
# DETECT_MAX_FRAMES=8

# ── Runner knobs (env only; not secrets) ───────────────────────────────────
# OVERCAST_USE_NODE=1   # run `node dist/bin/overcast.js` instead of the bun binary
# SKIP_BUILD=1          # reuse an existing dist build (skip the build step)
# OC_TIMEOUT=300        # per-command timeout in seconds
