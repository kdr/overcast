# overcast — sample environment file.
#
#   cp .env.example .env   # then fill in the keys/paths you have
#
# `.env` is gitignored (never commit real secrets). It is sourced by the LIVE
# real-data e2e suite (test/e2e/live/run.sh) and is a convenient place to keep
# provider creds for local CLI use. EVERYTHING here is OPTIONAL: each e2e case
# gates on what it needs and SKIPS (counted as pass) when a key/tool/clip is
# absent, so the suite runs green with any subset.

# ── Sense / brain providers ────────────────────────────────────────────────
# Default watch/listen backend (Cloudglue via the tinycloud CLI), also a pickable
# brain LLM. https://cloudglue.dev
CLOUDGLUE_API_KEY=
# Hugging Face — turnkey `see` captioner + `enhance`, and model downloads for the
# local object detector. https://huggingface.co/settings/tokens
HF_TOKEN=
# fal.ai — `see` (florence-2 caption/OCR) + `enhance` (esrgan). https://fal.ai/dashboard/keys
FAL_KEY=
# ElevenLabs — `listen` (Scribe STT) + `enhance` (voice isolation). https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── OSINT sources (scan/capture/monitor) ───────────────────────────────────
# Web search: Tavily preferred, Brave as fallback (set either).
TAVILY_API_KEY=
BRAVE_API_KEY=
# TikTok + X/Twitter enumerate + lens reverse image search (Apify actors);
# tiktok fetch uses yt-dlp, x fetch uses yt-dlp / direct CDN. https://apify.com
APIFY_TOKEN=

# ── Test media (LIVE e2e) — one full path per file ─────────────────────────
# Point each at a real local file (absolute path). No file names are baked into
# the repo. A case SKIPS when its file is unset or missing, so fill in only what
# you have.
# Videos:
OC_VIDEO_VISUAL=/path/to/screen-recording.mp4     # rich on-screen visual (~30s) — watch / see
OC_VIDEO_OBJECTS=/path/to/people-and-objects.mp4  # people + detectable objects — see --detect
OC_VIDEO_SMALL=/path/to/small-clip.mp4            # short / small — enhance / view
OC_VIDEO_SPEECH=/path/to/clip-with-speech.mp4     # clear spoken audio — listen (audio fallback)
# Standalone image + audio (used directly by see / listen; if unset, those fall
# back to a frame / audio extracted from the videos above):
OC_IMAGE=/path/to/photo.jpg                       # image — see (caption / OCR / detect)
OC_AUDIO=/path/to/recording.m4a                   # audio — listen

# Local visual DB real-data e2e (test/e2e/live/cases/16_visual_db.sh):
OC_LOCAL_FACE_VIDEO=/path/to/video-with-person.mp4
OC_LOCAL_FACE_IMAGE=/path/to/person-reference.jpg
# Face-CLUSTER real-data e2e (test/e2e/live/cases/17_face_cluster.sh): a folder of
# curated CLEAN crops of TWO distinct people — willsmith_ref.jpg + willsmith_N.jpg
# (one person) and personB_N.jpg (another). The test ingests them, clusters, and
# checks a held-out identify picks the right person. If unset, that case falls back
# to ingesting OC_LOCAL_FACE_VIDEO (looser assertions). Needs the --face venv below.
OC_CLUSTER_FIXTURE_DIR=/path/to/face-crops
OC_LOCAL_IMAGE_REF=/path/to/logo-reference.jpg
OC_LOCAL_IMAGE_VIDEO_A=/path/to/candidate-a.mp4
OC_LOCAL_IMAGE_VIDEO_B=/path/to/candidate-b.mp4
# Local basic-clip (CLIP semantic) DB e2e (test/e2e/live/cases/17_clip_db.sh).
# ALL OPTIONAL — when unset, the case derives real fixtures itself: it clips
# OC_VIDEO_OBJECTS/OC_VIDEO_SMALL, extracts frames with ffmpeg, and captions a
# frame with `see` to produce the text queries.
# OC_CLIP_VIDEO=/path/to/scene-video.mp4          # video A override (embedded, frame-sampled)
# OC_CLIP_IMAGE_REF=/path/to/reference.jpg        # image-member override
# OC_CLIP_TEXT=a red car at night                 # fallback text query when `see` is unavailable
# Python for local image/face/CLIP DB providers. Recommended setup:
#   scripts/visual-db-uv.sh          # image DB deps
#   scripts/visual-db-uv.sh --face   # image + face DB deps
#   scripts/visual-db-uv.sh --clip   # CLIP (open_clip + torch) DB deps
#   scripts/visual-db-uv.sh --all    # all of the above
# Then set this to the printed venv Python if you do not use the default path.
OC_VISUAL_DB_PY=
# Optional CLIP model overrides (defaults: ViT-B-32 / openai weights / cpu):
# OC_CLIP_MODEL=ViT-B-32
# OC_CLIP_PRETRAINED=openai
# OC_CLIP_DEVICE=cpu
# Optional LIVE e2e assertion thresholds. Normal CLI use can omit these and pass
# flags per command instead. Provider defaults when flags are omitted are:
# image min-inliers=15 min-ratio=0.4 max-frames=8; face min-similarity=68 max-frames=8.
# When fps is provided, max-frames becomes an optional cap.
# OC_LOCAL_IMAGE_MIN_INLIERS=8
# OC_LOCAL_IMAGE_MIN_RATIO=0.25
# OC_LOCAL_IMAGE_FPS=0.7
# OC_LOCAL_IMAGE_MAX_FRAMES=12
# OC_LOCAL_FACE_MIN_SIMILARITY=45
# OC_LOCAL_FACE_FPS=0.5
# OC_LOCAL_FACE_MAX_FRAMES=24

# ── Local object detector (see --detect) ──────────────────────────────────
# Python interpreter that has torch + transformers + scipy + pillow installed
# (OWLv2 / Grounding DINO). If unset, the case probes python3/python and skips
# when the deps aren't present. e.g. /path/to/venv/bin/python
DETECT_PY=
# Optional detector tuning (defaults shown):
# DETECT_MODEL=google/owlv2-base-patch16-ensemble
# DETECT_THRESHOLD=0.1
# DETECT_MAX_FRAMES=8

# ── Runner knobs (env only; not secrets) ───────────────────────────────────
# OVERCAST_USE_NODE=1   # run `node dist/bin/overcast.js` instead of the bun binary
# SKIP_BUILD=1          # reuse an existing dist build (skip the build step)
# OC_TIMEOUT=300        # per-command timeout in seconds
